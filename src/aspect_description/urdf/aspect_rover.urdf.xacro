<?xml version="1.0"?>
<robot name="aspect_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================
       ASPECT Rover — stub URDF/xacro
       1:10 scale, 4-wheel differential drive, 15cm x 10cm x 8cm chassis
       TODO: Replace box geometry with proper mesh files
       ================================================================ -->

  <!-- Chassis dimensions (metres) -->
  <xacro:property name="chassis_length" value="0.15"/>
  <xacro:property name="chassis_width"  value="0.10"/>
  <xacro:property name="chassis_height" value="0.08"/>
  <xacro:property name="chassis_mass"   value="0.2"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_radius" value="0.02"/>
  <xacro:property name="wheel_width"  value="0.015"/>
  <xacro:property name="wheel_mass"   value="0.025"/>
  <xacro:property name="wheelbase_x"  value="0.05"/>
  <xacro:property name="wheelbase_y"  value="0.055"/>

  <!-- Auger dimensions (Phase 1 box-geometry stub) -->
  <!--   auger_radius  = drill radius (m)                               -->
  <!--   auger_length  = body/housing length (m)                        -->
  <!--   auger_feed_travel = max prismatic travel downward (m)          -->
  <!--   nominal rotation ~120 RPM = 12.57 rad/s                        -->
  <!--   nominal feed velocity 10 mm/s = 0.01 m/s                      -->
  <xacro:property name="auger_radius"      value="0.015"/>
  <xacro:property name="auger_length"      value="0.08"/>
  <xacro:property name="auger_feed_travel" value="0.05"/>
  <xacro:property name="auger_mass"        value="0.060"/>

  <!-- ======================== Base links ======================== -->

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <!-- Box inertia: ixx=m(y²+z²)/12, iyy=m(x²+z²)/12, izz=m(x²+y²)/12 -->
      <inertia ixx="0.000273" ixy="0.0" ixz="0.0"
               iyy="0.000482" iyz="0.0"
               izz="0.000542"/>
    </inertial>
  </link>

  <!-- ======================== Wheel macro ======================== -->

  <xacro:macro name="wheel" params="prefix reflect_lr reflect_fb">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <!-- Cylinder inertia: ixx=iyy=m(3r²+h²)/12, izz=mr²/2 -->
        <inertia ixx="0.0000030" ixy="0.0" ixz="0.0"
                 iyy="0.0000030" iyz="0.0"
                 izz="0.0000050"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="${reflect_fb * wheelbase_x} ${reflect_lr * wheelbase_y} 0"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Instantiate 4 wheels -->
  <xacro:wheel prefix="front_left"  reflect_lr=" 1" reflect_fb=" 1"/>
  <xacro:wheel prefix="front_right" reflect_lr="-1" reflect_fb=" 1"/>
  <xacro:wheel prefix="rear_left"   reflect_lr=" 1" reflect_fb="-1"/>
  <xacro:wheel prefix="rear_right"  reflect_lr="-1" reflect_fb="-1"/>

  <!-- ======================== IMU ======================== -->

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.005"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
               iyy="0.000001" iyz="0.0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${chassis_height / 2 + 0.005}" rpy="0 0 0"/>
  </joint>

  <!-- ======================== Camera ======================== -->

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.015 0.03 0.01"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.010"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
               iyy="0.000001" iyz="0.0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${chassis_length / 2 + 0.005} 0 0.02" rpy="0 0.1 0"/>
  </joint>

  <link name="camera_optical_link"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ======================== Excavation Auger ======================== -->

  <!--
    Phase 1 stub: box-geometry drill body sufficient to unblock T-103 gym env.
    Two articulation joints:
      auger_feed_joint     — prismatic along -Z (vertical feed, 0–50 mm travel)
      auger_rotation_joint — continuous around Z (drill spin, ≤12.57 rad/s)
    ROS 2 interface (bridged via ros_gz_bridge):
      publishes  /excavation/joint_state  (sensor_msgs/JointState)
      subscribes /excavation/cmd          (aspect_msgs/AugerCmd: rpm, feed_rate)
    Phase 3 thermal extension (T-302): add resistive heating plugin to
    auger_housing_link — plugin slot reserved in <gazebo> block below.
    TODO: replace cylinder geometry with mesh once T-302 hardware design is final.
    Reference: NASA LADI auger architecture (AIAA 2023-4758). See D-013, D-014.
  -->

  <!-- Mount bracket — fixed to front-bottom of chassis -->
  <link name="auger_mount_link">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.005"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0"
               iyy="0.000001" iyz="0.0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="auger_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="auger_mount_link"/>
    <!-- Front-centre, flush with chassis bottom -->
    <origin xyz="${chassis_length / 2} 0 ${-(chassis_height / 2)}" rpy="0 0 0"/>
  </joint>

  <!-- Auger housing — translates vertically (vertical feed axis) -->
  <link name="auger_housing_link">
    <visual>
      <origin xyz="0 0 ${-(auger_length / 2)}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${auger_radius}" length="${auger_length}"/>
      </geometry>
      <material name="silver">
        <color rgba="0.75 0.75 0.75 1.0"/>
      </material>
    </visual>
    <!-- No collision: auger spawns below ground plane (mount is flush with chassis
         bottom at -0.02m world-z); terrain contact added with real mesh in T-301. -->
    <inertial>
      <origin xyz="0 0 ${-(auger_length / 2)}" rpy="0 0 0"/>
      <mass value="${auger_mass * 0.6}"/>
      <!-- Cylinder: ixx=iyy=m(3r²+l²)/12, izz=mr²/2 -->
      <!-- m=0.036, r=0.015, l=0.08 -->
      <inertia ixx="0.0000212" ixy="0.0" ixz="0.0"
               iyy="0.0000212" iyz="0.0"
               izz="0.0000041"/>
    </inertial>
  </link>

  <!--
    Prismatic joint: vertical feed.
    axis  = -Z (downward). lower=0 (retracted), upper=${auger_feed_travel} (50 mm).
    effort = 50 N (sufficient for 1:10 regolith penetration).
    velocity = 0.01 m/s (10 mm/s nominal feed rate).
  -->
  <joint name="auger_feed_joint" type="prismatic">
    <parent link="auger_mount_link"/>
    <child  link="auger_housing_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0" upper="${auger_feed_travel}"
           effort="50.0" velocity="0.01"/>
  </joint>

  <!-- Auger bit — rotates within housing -->
  <link name="auger_bit_link">
    <visual>
      <origin xyz="0 0 ${-(auger_length * 0.9 / 2)}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${auger_radius * 0.7}" length="${auger_length * 0.9}"/>
      </geometry>
      <material name="orange">
        <color rgba="0.9 0.5 0.1 1.0"/>
      </material>
    </visual>
    <!-- No collision: see auger_housing_link note above. -->
    <inertial>
      <origin xyz="0 0 ${-(auger_length * 0.9 / 2)}" rpy="0 0 0"/>
      <mass value="${auger_mass * 0.4}"/>
      <!-- m=0.024, r=0.0105, l=0.072 -->
      <inertia ixx="0.0000107" ixy="0.0" ixz="0.0"
               iyy="0.0000107" iyz="0.0"
               izz="0.0000013"/>
    </inertial>
  </link>

  <!--
    Continuous joint: drill spin.
    axis  = -Z (right-hand rule; anticlockwise from above = forward auger cut).
    effort   = 2.0 N·m (ample for 1:10 regolith).
    velocity = 12.57 rad/s (~120 RPM nominal).
  -->
  <joint name="auger_rotation_joint" type="continuous">
    <parent link="auger_housing_link"/>
    <child  link="auger_bit_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit effort="2.0" velocity="12.57"/>
  </joint>

  <!-- ======================== Gazebo plugins ======================== -->

  <!--
    Differential drive plugin (Gazebo Harmonic / gz-sim-diff-drive-system).
    Left side: front_left + rear_left wheels.
    Right side: front_right + rear_right wheels.
    Topic names are in Gazebo namespace; ros_gz_bridge maps them to ROS 2.
  -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>${wheelbase_y * 2}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <!-- Gazebo topic that ros_gz_bridge will forward to /cmd_vel -->
      <topic>/model/aspect_rover/cmd_vel</topic>
      <odom_topic>/model/aspect_rover/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
  </gazebo>

  <!--
    Joint state publisher plugin — publishes wheel encoder positions so
    robot_state_publisher can compute TF for the four wheel joints.
  -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/model/aspect_rover/joint_states</topic>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <joint_name>auger_feed_joint</joint_name>
      <joint_name>auger_rotation_joint</joint_name>
    </plugin>
  </gazebo>

  <!--
    Auger thermal plugin slot (Phase 3 / T-302).
    Uncomment and fill in when resistive heating element is added to
    auger_housing_link in T-302.  Placeholder kept here so the xacro
    structure is clear and the link name is already established.
  -->
  <!--
  <gazebo reference="auger_housing_link">
    <plugin filename="gz-sim-thermal-system" name="gz::sim::systems::Thermal">
      <!\-\- TODO T-302: configure thermal properties \-\->
    </plugin>
  </gazebo>
  -->

  <!--
    IMU sensor plugin — publishes raw IMU data that robot_localization
    fuses with odometry via EKF.
  -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/model/aspect_rover/imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

</robot>
